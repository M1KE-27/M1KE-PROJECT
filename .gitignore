*.a
*.elf
*.exe
*.bin
*.log
*.tmp
*.swp

# Ignore distribution archives
*.zip
*.tar
*.tar.gz
*.tgz

# Ignore common package manager and build dirs
/node_modules/
/dist/

# Misc
.cache/
.pytest_cache/
